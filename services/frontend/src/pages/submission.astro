---

import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import Submit from "../components/Submit.astro";
import PastSubmit from "../components/Past_submit.astro";
import { getSession } from "../lib/auth";

const session = await getSession(Astro.request);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>MLSEC 2.0 - Submission</title>
	</head>
	<body class="flex flex-col min-h-screen bg-gray-50">
		<Navbar />
		{session ? (
			<div class="flex flex-1 flex-col md:flex-row">
				<Submit />
				<PastSubmit />
			</div>
		) : (
			<div class="flex flex-1 items-center justify-center">
				<p class="text-gray-500 text-sm">You are not logged in. Please <button id="login-prompt-btn" class="text-primary hover:underline font-medium">log in</button> to submit samples.</p>
			</div>
		)}
		<Footer />
	</body>
</html>

<script>
  document.getElementById('login-prompt-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-login-modal'));
  });
</script>
