---
const { title, endpoint } = Astro.props;
---

<div class="flex flex-col flex-grow">
  <h1 class="text-xl text-gray-900">{title}</h1>

  <div id="submissions-list" class="bg-gray-50 rounded-lg p-4 m-3 h-96 overflow-y-auto">
    <p class="text-gray-500">Loading submissions...</p>
  </div>
</div>

<script define:vars={{ endpoint }}>
  async function fetchSubmissions(retries = 5, delay = 1000) {
    const container = document.getElementById("submissions-list");
    if (!container) return;

    try {
      const res = await fetch(`${endpoint}?limit=50&offset=0`);
      if (!res.ok) throw new Error("Failed to fetch submissions");

      const data = await res.json();
      const items = data.items ?? [];

      if (items.length === 0) {
        if (retries > 0) {
          setTimeout(() => fetchSubmissions(retries - 1, delay), delay);
          return;
        }
        if (!container.querySelector("ul")) {
          container.innerHTML = `<p class="text-gray-500">No submissions found.</p>`;
        }
        return;
      }

      container.innerHTML = `
        <ul class="space-y-2 w-full">
          ${items.map((s) => `
            <li class="bg-white p-3 rounded shadow">
              <p class="font-semibold">${s.display_name}</p>
              <p class="text-sm text-gray-500">${s.version}</p>
              <p class="text-sm text-gray-600">${s.status}</p>
            </li>
          `).join("")}
        </ul>
      `;
    } catch (err) {
      if (retries > 0) {
        setTimeout(() => fetchSubmissions(retries - 1, delay), delay);
        return;
      }
      if (!container.querySelector("ul")) {
        container.innerHTML = `<p class="text-red-500">Failed to load submissions.</p>`;
      }
      console.error(err);
    }
  }

  setTimeout(() => fetchSubmissions(), 1000);

  // Re-fetch when a submission is made
  window.addEventListener("submission-made", () => fetchSubmissions(5, 1000));
</script>