---
import InputLink from "./InputLink.astro";
import TextField from "./TextField.astro";
import FileUpload from "./FileUpload.astro";
import SubmissionForm from "./Form.astro";
---

<div class="flex flex-col flex-1 bg-green-100 ml-6 mr-3 mt-6 mb-3 p-7 rounded-xl">
  <h1 class="text-2xl font-semibold text-gray-900 pb-2">Model Submission</h1>
  <SubmissionForm button_text="Submit Model">
    <div class="flex flex-col">
      <TextField title="Model Name" placeholder="Enter Model Name" id="model-name" required/>
      <TextField title="Model Version" placeholder="0.0.0" id="model-version" required/>
      <TextField title="Docker Hub Image:" placeholder="creator/image" id="docker-image"/>
      <InputLink title="DockerHub/GitHub Link:" placeholder="https://hub.docker.com/" submit_text="Submit Model"/>
      <div class="flex items-center my-2">
        <div class="flex-1 border-t border-gray-300"></div>
        <span class="px-2 text-sm text-gray-500 font-medium">OR</span>
        <div class="flex-1 border-t border-gray-300"></div>
      </div>
      <FileUpload title="Upload Docker Image File:" subtext="Uplaod Dockerfile up to 10Mb"/>
    </div>
  </SubmissionForm>
</div>

<script>
  const form = document.querySelector("form");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const modelName = (document.getElementById("model-name") as HTMLInputElement)?.value.trim();
    const modelVersion = (document.getElementById("model-version") as HTMLInputElement)?.value.trim();
    const dockerImage = (document.getElementById("docker-image") as HTMLInputElement)?.value.trim();
    const url = (document.getElementById("url") as HTMLInputElement)?.value.trim();
    const file = (document.getElementById("file") as HTMLInputElement)?.files?.[0];

    if (!url && !file && !dockerImage) {
      alert("Please provide a link or upload a file.");
      return;
    }

    try {
      let response: Response;

      if (file) {
        const formData = new FormData();
        formData.append("file", file);
        formData.append("version", modelVersion);
        formData.append("display_name", modelName);

        response = await fetch("/api/submissions/defense/zip", {
          method: "POST",
          body: formData,
        });

      } else if (url) {
        response = await fetch("/api/submissions/defense/github", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            git_repo: url,
            version: modelVersion,
            display_name: modelName,
          }),
        });

      } else {
        response = await fetch("/api/submissions/defense/docker", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            docker_image: dockerImage,
            version: modelVersion,
            display_name: modelName,
          }),
        });
      }

      if (!response.ok) {
        const error = await response.text();
        alert(`Submission failed: ${error}`);
        return;
      }

      alert("Model submitted successfully!");

    } catch (err) {
      alert(`Network error: ${err.message}`);
    }
  });
</script>