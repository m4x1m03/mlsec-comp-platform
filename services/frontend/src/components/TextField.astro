---
const {title, placeholder, id, required} = Astro.props;
---

<div class="w-full max-w-md mx-auto p-6">
    <div>
      <label
        for={id}
        class="block text-sm font-medium text-gray-700 mb-2"
      >
        {title}
        {required && <span class="text-red-500 ml-0.5">*</span>}
      </label>
      <input
        type="text"
        id={id}
        name={id}
        placeholder={placeholder}
        required={required}
        class="w-full px-4 py-2 border-2 border-gray-300 bg-gray-50 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition"
      />
    </div>
</div>