---
---

<div class="flex flex-col flex-1 bg-white border border-gray-200 shadow-sm ml-6 mr-3 mb-6 mt-3 p-6 rounded-xl">
  <h2 class="text-xl font-semibold text-gray-900 mb-5">Attack Submission</h2>

  <form id="attack-form" class="flex flex-col gap-4">

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">ZIP Archive</label>
      <label
        for="attack-file"
        id="attack-file-label"
        class="flex flex-col items-center justify-center w-full h-32 border-2 border-dashed border-gray-300 rounded-xl cursor-pointer bg-gray-50 hover:bg-gray-100 transition"
      >
        <div id="attack-file-idle" class="flex flex-col items-center text-center px-4">
          <svg class="w-8 h-8 mb-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6H16a5 5 0 011 9.9M12 12v9m0 0l-3-3m3 3l3-3" />
          </svg>
          <p class="text-sm text-gray-600">
            <span class="font-medium text-primary">Click to upload</span> or drag and drop
          </p>
          <p class="text-xs text-gray-400 mt-0.5">Password-protected ZIP (password: "infected"), max 5 MB per sample</p>
        </div>
        <div id="attack-file-chosen" class="hidden flex-col items-center text-center px-4">
          <svg class="w-8 h-8 mb-2 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p id="attack-file-name" class="text-sm font-medium text-gray-800 truncate max-w-xs"></p>
          <p class="text-xs text-gray-400 mt-0.5">Click to change</p>
        </div>
        <input id="attack-file" name="file" type="file" accept=".zip" class="hidden" />
      </label>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <label for="attack-name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
        <input
          type="text"
          id="attack-name"
          name="display_name"
          placeholder="My Attack"
          class="w-full px-3 py-2 border border-gray-300 bg-gray-50 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
        />
      </div>
      <div>
        <label for="attack-version" class="block text-sm font-medium text-gray-700 mb-1">Version</label>
        <input
          type="text"
          id="attack-version"
          name="version"
          placeholder="1.0.0"
          pattern="[0-9]+[.][0-9]+[.][0-9]+"
          required
          class="w-full px-3 py-2 border border-gray-300 bg-gray-50 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition"
        />
      </div>
    </div>

    <div id="attack-feedback" class="hidden text-sm rounded-lg px-3 py-2"></div>

    <button
      type="submit"
      class="w-full bg-primary hover:bg-secondary text-white font-semibold py-2.5 rounded-lg transition duration-200"
    >
      Submit Attack
    </button>

  </form>
</div>

<script>
  const attackFileInput = document.getElementById('attack-file') as HTMLInputElement;
  const attackIdleView  = document.getElementById('attack-file-idle')!;
  const attackChosenView = document.getElementById('attack-file-chosen')!;
  const attackFileNameEl = document.getElementById('attack-file-name')!;

  attackFileInput.addEventListener('change', () => {
    const file = attackFileInput.files?.[0];
    if (file) {
      attackFileNameEl.textContent = file.name;
      attackIdleView.classList.add('hidden');
      attackChosenView.classList.remove('hidden');
      attackChosenView.classList.add('flex');
    } else {
      attackIdleView.classList.remove('hidden');
      attackChosenView.classList.add('hidden');
      attackChosenView.classList.remove('flex');
    }
  });

  document.getElementById('attack-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();

    const feedback    = document.getElementById('attack-feedback')!;
    const btn         = document.querySelector<HTMLButtonElement>('#attack-form button[type="submit"]')!;
    const version     = (document.getElementById('attack-version') as HTMLInputElement).value.trim();
    const displayName = (document.getElementById('attack-name')    as HTMLInputElement).value.trim() || null;
    const fileInput   = document.getElementById('attack-file') as HTMLInputElement;
    const file        = fileInput.files?.[0];

    if (!file) {
      feedback.textContent = 'Please select a ZIP file.';
      feedback.className   = 'text-sm rounded-lg px-3 py-2 bg-red-50 text-red-700 border border-red-200';
      return;
    }

    btn.disabled    = true;
    btn.textContent = 'Submitting...';
    feedback.className = 'hidden text-sm rounded-lg px-3 py-2';

    try {
      const fd = new FormData();
      fd.append('file', file);
      fd.append('version', version);
      if (displayName) fd.append('display_name', displayName);

      const res  = await fetch('/api/submissions/attack/zip', { method: 'POST', body: fd });
      const data = await res.json();
      if (!res.ok) throw new Error(data.detail ?? `Error ${res.status}`);

      feedback.textContent = `Submitted (ID: ${data.submission_id})`;
      feedback.className   = 'text-sm rounded-lg px-3 py-2 bg-green-50 text-green-700 border border-green-200';
      (e.target as HTMLFormElement).reset();
      attackIdleView.classList.remove('hidden');
      attackChosenView.classList.add('hidden');
      attackChosenView.classList.remove('flex');
      document.dispatchEvent(new CustomEvent('submission-created', { detail: { type: 'attack' } }));

    } catch (err: unknown) {
      feedback.textContent = (err instanceof Error ? err.message : null) ?? 'Submission failed.';
      feedback.className   = 'text-sm rounded-lg px-3 py-2 bg-red-50 text-red-700 border border-red-200';
    } finally {
      btn.disabled    = false;
      btn.textContent = 'Submit Attack';
    }
  });
</script>
