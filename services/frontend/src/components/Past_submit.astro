---
import SubmissionHistory from './SubmissionHistory';
---

<div class="flex flex-col w-96 shrink-0 bg-white border border-gray-200 shadow-sm ml-3 mr-6 my-6 p-6 rounded-xl overflow-hidden">
  <div class="flex items-center justify-between mb-4 shrink-0">
    <h1 class="text-xl font-semibold text-gray-900">Submission History</h1>
    <div class="relative">
      <button
        id="status-info-btn"
        aria-label="Status definitions"
        class="p-1 rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a.75.75 0 000 1.5h.253a.25.25 0 01.244.304l-.459 2.066A1.75 1.75 0 0010.747 15H11a.75.75 0 000-1.5h-.253a.25.25 0 01-.244-.304l.459-2.066A1.75 1.75 0 009.253 9H9z" clip-rule="evenodd" />
        </svg>
      </button>
      <div
        id="status-info-popover"
        class="hidden absolute right-0 top-7 z-10 w-64 bg-white border border-gray-200 rounded-xl shadow-lg p-4"
      >
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Status Definitions</p>
        <ul class="flex flex-col gap-2.5">
          <li class="flex items-start gap-2.5">
            <span class="text-xs text-gray-400 font-medium w-20 shrink-0 mt-0.5">Submitted</span>
            <span class="text-xs text-gray-600">Queued and waiting to be processed.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-xs text-amber-500 font-semibold w-20 shrink-0 mt-0.5">Evaluating</span>
            <span class="text-xs text-gray-600">Currently being built and validated.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-xs text-green-600 font-semibold w-20 shrink-0 mt-0.5">Evaluated</span>
            <span class="text-xs text-gray-600">Validation passed and submission is active.</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-xs text-red-600 font-semibold w-20 shrink-0 mt-0.5">Error</span>
            <span class="text-xs text-gray-600">Processing failed. Expand the row for details.</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
  <div class="flex flex-col flex-1 gap-3 min-h-0">
    <SubmissionHistory type="defense" title="Defense Submissions" client:load />
    <SubmissionHistory type="attack" title="Attack Submissions" client:load />
  </div>
</div>

<script>
  const btn = document.getElementById('status-info-btn')!;
  const popover = document.getElementById('status-info-popover')!;

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    popover.classList.toggle('hidden');
  });

  document.addEventListener('click', () => {
    popover.classList.add('hidden');
  });
</script>
