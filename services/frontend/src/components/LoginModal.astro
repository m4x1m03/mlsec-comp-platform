---
// src/components/LoginModal.astro
---

<div
  id="login-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
>
  <div
    id="login-modal-card"
    class="relative w-full max-w-lg mx-4 bg-white rounded-2xl shadow-2xl p-8 scale-95 opacity-0 transition-all duration-200"
  >
    <button
      id="login-modal-close"
      class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors"
      aria-label="Close modal"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </button>

    <div class="flex gap-1 mb-6 bg-gray-100 p-1 rounded-lg w-fit mx-auto">
      <button
        id="tab-login"
        class="tab-btn px-5 py-1.5 rounded-md text-sm font-bold transition-colors duration-150 bg-white text-gray-900 shadow-sm"
        data-tab="login"
      >
        Sign In
      </button>
      <button
        id="tab-register"
        class="tab-btn px-5 py-1.5 rounded-md text-sm font-bold transition-colors duration-150 text-gray-500 hover:text-gray-700"
        data-tab="register"
      >
        Register
      </button>
    </div>

    <div id="panel-login">
      <form id="login-form" class="flex flex-col gap-3">
        <div class="flex flex-col gap-1.5 flex-1">
          <label
            for="login-email"
            class="text-sm font-semibold text-gray-700 tracking-wide uppercase"
            >Email</label
          >
          <input
            type="email"
            id="login-email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-secondary focus:border-transparent transition"
          />
        </div>
        <p
          id="login-error"
          class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"
        >
        </p>
        <button
          type="submit"
          class="px-5 bg-primary hover:bg-secondary text-white py-2.5 rounded-lg transition duration-200 ease-in-out font-bold tracking-wide whitespace-nowrap"
        >
          Login
        </button>
      </form>

      <form id="login-code-form" class="hidden flex flex-col gap-3">
        <div
          id="login-code-message"
          class="text-sm text-gray-600 bg-gray-50 border border-gray-200 rounded-lg px-3 py-2"
        >
        </div>
        <div class="flex flex-col gap-1.5 flex-1">
          <label
            for="login-code"
            class="text-sm font-semibold text-gray-700 tracking-wide uppercase"
            >Verification Code</label
          >
          <input
            type="text"
            id="login-code"
            name="code"
            inputmode="numeric"
            autocomplete="one-time-code"
            required
            placeholder="123456"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-secondary focus:border-transparent transition"
          />
        </div>
        <p
          id="login-code-error"
          class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"
        >
        </p>
        <div class="flex flex-wrap items-center gap-2">
          <button
            type="submit"
            class="px-5 bg-primary hover:bg-secondary text-white py-2.5 rounded-lg transition duration-200 ease-in-out font-bold tracking-wide whitespace-nowrap"
          >
            Verify
          </button>
          <button
            type="button"
            id="login-code-resend"
            class="px-5 py-2.5 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition duration-200 ease-in-out font-bold tracking-wide whitespace-nowrap"
          >
            Resend
          </button>
          <button
            type="button"
            id="login-code-edit"
            class="px-5 py-2.5 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition duration-200 ease-in-out font-bold tracking-wide whitespace-nowrap"
          >
            Edit Email
          </button>
        </div>
      </form>
    </div>

    <div id="panel-register" class="hidden">
      <form id="register-form" class="flex flex-col gap-4">
        <div class="flex flex-col gap-3">
          <div class="flex flex-col gap-1.5 flex-1">
            <label
              for="register-email"
              class="text-sm font-semibold text-gray-700 tracking-wide uppercase"
              >Email</label
            >
            <input
              type="email"
              id="register-email"
              name="email"
              required
              placeholder="you@example.com"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div class="flex flex-col gap-1.5 flex-1">
            <label
              for="register-username"
              class="text-sm font-semibold text-gray-700 tracking-wide uppercase"
              >Username</label
            >
            <input
              type="text"
              id="register-username"
              name="username"
              required
              placeholder="Username"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div id="join-code-field" class="hidden flex-col gap-1.5 flex-1">
            <label
              for="register-join-code"
              class="text-sm font-semibold text-gray-700 tracking-wide uppercase"
              >Join Code</label
            >
            <input
              type="text"
              id="register-join-code"
              name="join_code"
              placeholder="Enter join code"
              class="w-full px-4 py-2.5 rounded-lg border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
        </div>
        <p
          id="register-error"
          class="hidden text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2"
        >
        </p>
        <button
          type="submit"
          class="px-5 bg-primary hover:bg-secondary text-white py-2.5 rounded-lg transition duration-200 ease-in-out font-bold tracking-wide whitespace-nowrap"
        >
          Create Account
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("login-modal")!;
  const card = document.getElementById("login-modal-card")!;
  const closeBtn = document.getElementById("login-modal-close")!;
  const tabBtns = document.querySelectorAll<HTMLButtonElement>(".tab-btn");

  // Tab switching
  tabBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.dataset.tab!;

      // Update tab styles
      tabBtns.forEach((b) => {
        const active = b.dataset.tab === target;
        b.classList.toggle("bg-white", active);
        b.classList.toggle("text-gray-900", active);
        b.classList.toggle("shadow-sm", active);
        b.classList.toggle("text-gray-500", !active);
      });

      // Show/hide panels
      document
        .getElementById("panel-login")!
        .classList.toggle("hidden", target !== "login");
      document
        .getElementById("panel-register")!
        .classList.toggle("hidden", target !== "register");
    });
  });

  function openModal(tab = "login") {
    modal.classList.remove("hidden");
    modal.classList.add("flex");
    // Activate the correct tab
    document
      .querySelector<HTMLButtonElement>(`.tab-btn[data-tab="${tab}"]`)
      ?.click();
    requestAnimationFrame(() => {
      card.classList.remove("scale-95", "opacity-0");
      card.classList.add("scale-100", "opacity-100");
    });
  }

  function closeModal() {
    card.classList.remove("scale-100", "opacity-100");
    card.classList.add("scale-95", "opacity-0");
    setTimeout(() => {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
    }, 200);
  }

  document.addEventListener("open-login-modal", (e: Event) => {
    const tab = (e as CustomEvent).detail?.tab ?? "login";
    openModal(tab);
  });

  window.addEventListener("pageshow", (e) => {
    if (e.persisted) {
      (document.getElementById("login-form") as HTMLFormElement)?.reset();
      (document.getElementById("register-form") as HTMLFormElement)?.reset();
    }
  });

  closeBtn.addEventListener("click", closeModal);
  modal.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) closeModal();
  });
</script>

<script>
  // login + email verification flow
  const loginForm = document.getElementById("login-form")!;
  const loginCodeForm = document.getElementById("login-code-form")!;
  const loginEmailInput = document.getElementById(
    "login-email",
  ) as HTMLInputElement;
  const loginCodeInput = document.getElementById(
    "login-code",
  ) as HTMLInputElement;
  const loginError = document.getElementById("login-error")!;
  const loginCodeError = document.getElementById("login-code-error")!;
  const loginCodeMessage = document.getElementById("login-code-message")!;
  const resendBtn = document.getElementById(
    "login-code-resend",
  ) as HTMLButtonElement;
  const editBtn = document.getElementById(
    "login-code-edit",
  ) as HTMLButtonElement;

  let pendingEmail = "";

  function showEmailStep() {
    loginForm.classList.remove("hidden");
    loginCodeForm.classList.add("hidden");
    loginCodeInput.value = "";
    loginCodeMessage.textContent = "";
    loginCodeError.classList.add("hidden");
  }

  function showCodeStep(email: string, expiresAt?: string | null) {
    pendingEmail = email;
    loginForm.classList.add("hidden");
    loginCodeForm.classList.remove("hidden");
    loginCodeError.classList.add("hidden");
    const expiry = expiresAt ? new Date(expiresAt) : null;
    const expiryText = expiry
      ? ` Expires at ${expiry.toLocaleTimeString()}.`
      : "";
    loginCodeMessage.textContent = `We sent a verification code to ${email}.${expiryText}`;
    loginCodeInput.focus();
  }

  async function requestLoginCode(email: string) {
    loginError.classList.add("hidden");
    loginCodeError.classList.add("hidden");

    const res = await fetch("/auth/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email }),
    });

    const data = await res.json().catch(() => ({}));

    if (!res.ok) {
      loginError.textContent = data.detail ?? "Login failed.";
      loginError.classList.remove("hidden");
      showEmailStep();
      return;
    }

    if (data.requires_registration) {
      loginError.textContent = "Email not recognized. Please register first.";
      loginError.classList.remove("hidden");
      showEmailStep();
      return;
    }

    if (data.authenticated) {
      (document.getElementById("login-form") as HTMLFormElement).reset();
      (document.getElementById("register-form") as HTMLFormElement).reset();
      window.location.href = "/submission";
      return;
    }

    if (data.verification_required) {
      showCodeStep(email, data.verification_expires_at);
      return;
    }

    loginError.textContent = "Unexpected login response.";
    loginError.classList.remove("hidden");
    showEmailStep();
  }

  loginForm.addEventListener("submit", async function (e) {
    e.preventDefault();
    const email = loginEmailInput.value.trim();
    if (!email) return;
    await requestLoginCode(email);
  });

  loginCodeForm.addEventListener("submit", async function (e) {
    e.preventDefault();
    loginCodeError.classList.add("hidden");

    const code = loginCodeInput.value.trim();
    if (!pendingEmail || !code) return;

    const res = await fetch("/auth/login/verify", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email: pendingEmail, code }),
    });

    const data = await res.json().catch(() => ({}));

    if (!res.ok) {
      loginCodeError.textContent = data.detail ?? "Verification failed.";
      loginCodeError.classList.remove("hidden");
      return;
    }

    if (data.authenticated) {
      window.location.href = "/submission";
      return;
    }

    loginCodeError.textContent = "Verification failed.";
    loginCodeError.classList.remove("hidden");
  });

  resendBtn.addEventListener("click", async () => {
    if (!pendingEmail) return;
    await requestLoginCode(pendingEmail);
  });

  editBtn.addEventListener("click", () => {
    pendingEmail = "";
    showEmailStep();
    loginEmailInput.focus();
  });

  document.addEventListener("open-login-modal", () => {
    showEmailStep();
    loginError.classList.add("hidden");
  });

  document.getElementById("tab-login")?.addEventListener("click", () => {
    showEmailStep();
  });

  document.addEventListener("show-verify-step", (e: Event) => {
    const { email, expiresAt } = (e as CustomEvent).detail;
    pendingEmail = email;
    document
      .querySelector<HTMLButtonElement>('.tab-btn[data-tab="login"]')
      ?.click();
    showCodeStep(email, expiresAt);
  });
</script>

<script>
  //register logic
  async function checkJoinCodeRequired() {
    try {
      const res = await fetch("/auth/join-code/required");
      if (!res.ok) return;
      const data = await res.json();
      const joinCodeField = document.getElementById("join-code-field")!;
      const joinCodeInput = document.getElementById(
        "register-join-code",
      ) as HTMLInputElement;
      if (data.required) {
        joinCodeField.classList.remove("hidden");
        joinCodeField.classList.add("flex");
        joinCodeInput.required = true;
      } else {
        joinCodeField.classList.add("hidden");
        joinCodeField.classList.remove("flex");
        joinCodeInput.required = false;
      }
    } catch {
      // If the check fails, leave the field hidden and let the backend enforce.
    }
  }

  document
    .getElementById("tab-register")!
    .addEventListener("click", checkJoinCodeRequired);
  document.addEventListener("open-login-modal", (e: Event) => {
    const tab = (e as CustomEvent).detail?.tab ?? "login";
    if (tab === "register") checkJoinCodeRequired();
  });

  document
    .getElementById("register-form")!
    .addEventListener("submit", async function (e) {
      e.preventDefault();

      const email = (
        document.getElementById("register-email") as HTMLInputElement
      ).value;
      const username = (
        document.getElementById("register-username") as HTMLInputElement
      ).value;
      const joinCode =
        (document.getElementById("register-join-code") as HTMLInputElement)
          .value || null;
      const errorEl = document.getElementById("register-error")!;
      errorEl.classList.add("hidden");

      const res = await fetch("/auth/register", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          email: email,
          username: username,
          join_code: joinCode,
        }),
      });

      const data = await res.json().catch(() => ({}));

      if (!res.ok) {
        errorEl.textContent = data.detail ?? "Registration failed.";
        errorEl.classList.remove("hidden");
        return;
      }

      if (data.verification_required) {
        document.dispatchEvent(
          new CustomEvent("show-verify-step", {
            detail: { email, expiresAt: data.verification_expires_at },
          }),
        );
        return;
      }

      if (data.authenticated) {
        window.location.href = "/submission";
        return;
      }

      errorEl.textContent = "Unexpected registration response.";
      errorEl.classList.remove("hidden");
    });
</script>
