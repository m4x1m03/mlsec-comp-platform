# Secrets and host-specific deployment values.
# Non-secret application settings (email behavior, timeouts, limits) live in config.yaml.

# PostgreSQL credentials
POSTGRES_USER=mlsec
POSTGRES_PASSWORD=changeme

# MinIO object storage credentials
MINIO_ROOT_USER=mlsec
MINIO_ROOT_PASSWORD=changeme

# RabbitMQ credentials
RABBITMQ_USER=mlsec
RABBITMQ_PASSWORD=changeme

# Host Docker group ID - run: getent group docker | cut -d: -f3
DOCKER_GID=999

# VirusTotal API key (required when attack.sandbox_backend = "virustotal" in config.yaml)
VIRUSTOTAL_API_KEY=

# CAPE sandbox credentials (required when attack.sandbox_backend = "cape" in config.yaml)
CAPE_URL=
CAPE_USERNAME=
CAPE_PASSWORD=

# SMTP credentials (required when email.delivery = "smtp" in config.yaml)
SMTP_USER=
SMTP_PASSWORD=

# Worker concurrency: parallel tasks per worker container, uses Celery's built in concurrency (Not recommended to change) 
WORKER_CONCURRENCY=1

# Production only: public-facing API URL for the frontend (e.g. https://mlsec2.com)
PUBLIC_API_URL=

# Production only: admin endpoint access control (uncomment and set for your deployment)
# ADMIN_ALLOWED_HOSTS=["yourdomain.com"]
# ADMIN_TRUSTED_PROXY_HOSTS=["127.0.0.1", "::1", "172.16.0.0/12"]
# ADMIN_ALLOWED_NETWORKS=["172.16.0.0/12"]

# Production only: CORS settings
# CORS_ALLOW_ORIGINS=["https://yourdomain.com"]
# CORS_ALLOW_ORIGIN_REGEX=^https?://(yourdomain\.com|localhost|127\.0\.0\.1)(:\d+)?$